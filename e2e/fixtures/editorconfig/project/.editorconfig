root = true

[*]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.tabbed]
indent_style = tab
indent_size = 3
trim_trailing_whitespace = false
insert_final_newline = false

[*.crlf]
end_of_line = crlf

[*.lf]
end_of_line = lf

[*.latin]
charset = latin1
