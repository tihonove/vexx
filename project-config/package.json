{
  "name": "@vexx/project-config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Доска GitHub как код: декларативное описание полей Project и его синк",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "sync": "tsx src/cli.ts sync",
