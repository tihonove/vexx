    "test:watch": "vitest"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8",
    "vitest": "^4.0.18"
  }
}
