{
    "chat.tools.terminal.autoApprove": {
        "npm install": true,
        "npx vitest": true,
        "npx eslint": true,
        "git commit": true,
        "git push": true,
        "npx tsc": true,
        "cp": true
    },
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.test.ts, ${capture}.*.test.ts, ${capture}.stories.ts",
        "*.tsx": "${capture}.test.ts, ${capture}.*.test.ts, ${capture}.test.tsx, ${capture}.*.test.tsx, ${capture}.stories.ts, ${capture}.stories.tsx"
    },
    "jestrunner.enableTestExplorer": true,
    "editor.rulers": [
        120
    ]
}