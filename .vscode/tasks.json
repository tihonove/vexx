{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "npm test",
            "type": "npm",
            "script": "test",
            "problemMatcher": ["$tsc"],
            "detail": "npm test"
        },
        {
            "label": "npm lint",
            "type": "npm",
            "script": "lint",
            "problemMatcher": ["$eslint-compact"],
            "detail": "eslint src/"
        },
        {
            "label": "npm lint:fix",
            "type": "npm",
            "script": "lint:fix",
            "problemMatcher": ["$eslint-compact"],
            "detail": "eslint src/ --fix"
        },
        {
            "label": "npm typecheck",
            "type": "npm",
            "script": "typecheck",
            "problemMatcher": ["$tsc"],
            "detail": "tsc --noEmit"
        },
        {
            "label": "Run Story in External Terminal",
            "type": "shell",
            "command": "gnome-terminal",
            "args": [
                "--working-directory=${workspaceFolder}",
                "--",
                "bash",
                "-c",
                "npm run story -- ${relativeFile} ${selectedText}"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "Debug Story in External Terminal",
            "type": "shell",
            "command": "gnome-terminal",
            "args": [
                "--working-directory=${workspaceFolder}",
                "--",
                "bash",
                "-c",
                "npx tsx --inspect-brk=9229 src/StoryRunner/run.ts ${relativeFile} ${selectedText}"
            ],
            "isBackground": true,
            "problemMatcher": {
                "pattern": { "regexp": "^$" },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Debugger listening"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        }
    ]
}
