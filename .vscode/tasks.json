{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "npm test",
            "type": "npm",
            "script": "test",
            "problemMatcher": ["$tsc"],
            "detail": "npm test"
        },
        {
            "label": "npm lint",
            "type": "npm",
            "script": "lint",
            "problemMatcher": ["$eslint-compact"],
            "detail": "eslint src/"
        },
        {
            "label": "npm lint:fix",
            "type": "npm",
            "script": "lint:fix",
            "problemMatcher": ["$eslint-compact"],
            "detail": "eslint src/ --fix"
        },
        {
            "label": "npm typecheck",
            "type": "npm",
            "script": "typecheck",
            "problemMatcher": ["$tsc"],
            "detail": "tsc --noEmit"
        },
        {
            "label": "Run Story",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/run-story.sh ${relativeFile} ${selectedText}",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            }
        },
        {
            "label": "Debug Story",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/debug-story.sh ${relativeFile} ${selectedText}",
            "isBackground": true,
            "problemMatcher": {
                "pattern": { "regexp": "^$" },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Debugger listening"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        }
    ]
}
