// Роли агентов. Конфиг описывает ТОЛЬКО запуск: как собрать команду claude.
// Доска и её состояния живут в project-config/config.jsonc — это другой пакет.
//
// Перечитывается перед каждым запуском, так что правки ролей подхватываются
// без рестарта сервера. Рестарт нужен только при смене портов.
//
// Лимитов здесь НЕТ намеренно: все ограничения описаны прозой в скиллах.
// Роль = строчка здесь + каталог в .claude/skills/. Больше ничего добавлять не нужно.
{
  // Витрина публикуется наружу; MCP — только для claude внутри контейнера.
  "ports": { "dashboard": 7777, "mcp": 7778 },

  "roles": {
    // Оркестратор. Работает в основном репозитории и только читает его.
    // resume не задан → каждый запуск начинается с чистого листа. Это НАМЕРЕННО:
    // постоянная сессия копила бы контекст и уходила в компакт, давая частичную
    // память — она хуже, чем никакой, потому что ей начинаешь верить.
    "orchestrate": {
      "skill": "orchestrate",
      "worktree": false,
      "background": false,
      "everyMin": 10,
      // --tools сужает набор встроенных инструментов; --allowedTools лишь раздаёт
      // разрешения и сам по себе ничего не запрещает.
      "tools": "Bash Read Write Glob Grep",
      "allow": [
        "mcp__agents__list_agents",
        "mcp__agents__spawn_agent",
        "mcp__agents__stop_agent",
        "mcp__agents__agent_log",
        "Bash(gh *)",
        "Bash(node project-config/bin/status.mjs*)",
        "Read",
        "Write",
        "Glob",
        "Grep"
      ],
      "permissionMode": "acceptEdits"
    },

    // Реализатор. Своё дерево, фоном, с памятью между вызовами:
    // повторный запуск с тем же номером задачи продолжает прежний разговор.
    // bypassPermissions — потому что спрашивать некого: на любом вопросе фоновый
    // агент повис бы навсегда. Допустимо ровно потому, что он в отдельном worktree.
    "implement": {
      "skill": "implement",
      "worktree": true,
      "background": true,
      "resume": true,
      "tools": "default",
      "permissionMode": "bypassPermissions"
    }
  }
}
