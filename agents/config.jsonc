// Единственный источник правды по настройкам агентской машинерии.
// Состояния (лейблы/колонки) применяются командой `npm run sync`;
// секции ports/limits/roles/dryRun читает демон — на каждом тике заново,
// так что правки подхватываются без рестарта (кроме смены портов).
{
  "repo": "tihonove/vexx",
  "project": { "owner": "tihonove", "number": 2 },

  // Витрина публикуется наружу через appPort; MCP — только для claude внутри контейнера.
  "ports": { "dashboard": 7777, "mcp": 7778 },

  // Потолки живут здесь, а не в прозе скилла: инструкцию модель себе уговорит,
  // отказ от spawn_agent — нет.
  "limits": {
    "maxConcurrent": 2,
    "spawnsPerHour": 4,
    "tickIntervalMin": 10
  },

  // Режим наблюдения: оркестратор думает и пишет решения, но spawn_agent отказывает.
  "dryRun": true,

  // Роли агентов. Ключ — имя роли, skill — каталог в .claude/skills/.
  // Новая роль = новый скилл + строчка здесь.
  "roles": {
    "implement": { "skill": "implement" }
  },

  "labels": {
    // Юрисдикция синка: он владеет только лейблами с этим префиксом.
    // Всё остальное (bug, tech-debt, claude, …) не трогается никогда,
    // даже под --prune.
    "prefix": "agent:",
    "items": {
      "agent:bug": {
        "color": "0e8a16",
        "description": "Постановка готова, задачу можно брать агентом"
      }
    }
  },

  // Поля проекта. Порядок опций single-select = порядок колонок на доске.
  // Цвет опции — enum, не hex: GRAY | BLUE | GREEN | YELLOW | ORANGE | RED | PINK | PURPLE.
  "fields": {
    "Status": {
      "dataType": "SINGLE_SELECT",
      "options": [
        { "name": "Backlog", "color": "GRAY", "description": "Не разобрано" },
        { "name": "To implement", "color": "GREEN", "description": "Постановка готова, можно брать агентом" },
        // Implementing и Ready for review ставит сам агент, не оркестратор:
        // только он знает, что реально взялся и что реально довёл работу до конца.
        { "name": "Implementing", "color": "YELLOW", "description": "Агент в работе: пишет код, гоняет CI" },
        { "name": "Ready for review", "color": "BLUE", "description": "PR открыт и зелёный, ждёт человека" },
        { "name": "Done", "color": "PURPLE", "description": "Смёржено" }
      ]
    }
  }
}
