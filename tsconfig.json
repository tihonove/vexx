{
  "compilerOptions": {
    "target": "ES2024",
    "module": "Node16",
    "moduleResolution": "Node16",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "vscode-tui",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "vscode": ["src/Extensions/Api/vscode.d.ts"]
    }
  },
  "include": ["src"],
  "comment": "SPIKE (LSP): sample-проект имеет собственный tsconfig и грузится tsserver'ом, из общего typecheck исключён.",
  "exclude": ["src/Extensions/Host/__fixtures__/lspSample"]
}
