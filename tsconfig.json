{
  "compilerOptions": {
    "target": "ES2024",
    "module": "Node16",
    "moduleResolution": "Node16",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "vscode-tui",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "vscode": ["src/vscode-dts/vscode.d.ts"]
    }
  },
  "include": ["src", "extensions", "tuidom"],
  // Фикстуры — тестовые ДАННЫЕ, а не исходники: у diff-корпуса это .ts/.tsx/.tst
  // файлы из upstream, которые заведомо не компилируются в нашем проекте
  // (чужие импорты, свои расширения). Компилировать их незачем и нельзя.
  // Перечисляем и дефолты TS: наличие `exclude` их перекрывает.
  "exclude": ["node_modules", "dist", "**/__fixtures__/**"]
}
