{
  "name": "vscode-tui",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node src/main.ts",
    "demo:box": "node src/demos/boxDemo.ts",
    "demo:editor": "node src/demos/editorDemo.ts",
    "demo:events": "node src/demos/eventLogDemo.ts",
    "demo:raw-events": "node src/demos/tokenizeDemo.ts",
    "demo:renderer": "node src/demos/rendererDemo.ts",
    "demo:scroll": "node src/demos/scrollDemo.ts",
    "demo:menu-bar": "node src/demos/menuBarDemo.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.8",
    "typescript-eslint": "^8.56.1", 
    "vitest": "^4.0.18"
  }
}
