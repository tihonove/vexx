{
  "name": "vscode-tui",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    "./jsx-runtime": "./src/TUIDom/JSX/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/TUIDom/JSX/jsx-runtime.ts"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "tsx src/main.ts",
    "demo:editor": "node src/demos/editorDemo.ts",
    "demo:events": "node src/demos/eventLogDemo.ts",
    "demo:raw-events": "node src/demos/tokenizeDemo.ts",
    "demo:renderer": "node src/demos/rendererDemo.ts",
    "demo:mouse": "node src/demos/mouseDemo.ts",
    "story": "tsx src/StoryRunner/run.ts",
    "build": "tsup",
    "build:sea": "node scripts/build-sea.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jiti": "^2.6.1",
    "node-pty": "^1.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  }
}
