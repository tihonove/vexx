{
  "name": "vscode-tui",
  "version": "0.2.0",
  "type": "module",
  "exports": {
    "./jsx-runtime": "./src/TUIDom/JSX/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/TUIDom/JSX/jsx-runtime.ts"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "tsx src/main.ts",
    "prestart": "npm run build:extensions",
    "build:extensions": "node scripts/build-extensions.mjs",
    "demo:tuidom": "tsx src/demos/tuidom/minimalHost.ts",
    "demo:tuidom:inspect": "tsx src/demos/tuidom/inspectedHost.ts",
    "demo:events": "node src/demos/eventLogDemo.ts",
    "demo:raw-events": "node src/demos/tokenizeDemo.ts",
    "demo:renderer": "node src/demos/rendererDemo.ts",
    "demo:mouse": "node src/demos/mouseDemo.ts",
    "demo:terminal": "tsx src/demos/terminal/terminalHost.ts",
    "story": "tsx src/StoryRunner/run.ts",
    "screenshots": "tsx e2e/scenarios/generate.ts",
    "build": "tsup",
    "build:sea": "node scripts/build-sea.mjs",
    "build:selfextract": "node scripts/build-selfextract.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:perf": "vitest bench --run --config vitest.perf.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "@types/yauzl": "^3.4.0",
    "@types/yazl": "^3.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "ws": "^8.21.0",
    "yazl": "^3.3.1"
  },
  "dependencies": {
    "@xterm/headless": "^6.0.0",
    "chokidar": "^5.0.0",
    "iconv-lite": "^0.7.3",
    "jsonc-parser": "^3.3.1",
    "node-pty": "^1.1.0",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2",
    "vscode-uri": "^3.1.0",
    "yauzl": "^3.4.0"
  }
}
